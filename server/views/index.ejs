<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CodeVector Product Hub</title>
    <style>
        body {
            font-family: verdana, arial, sans-serif;
            background-color: #f8f9fa;
            color: #333;
            margin: 0;
            padding: 20px;
        }

        .container {
            max-width: 950px;
            margin: 0 auto;
            background: #fff;
            border: 1px solid #b9b9b9;
            border-radius: 4px;
            padding: 15px;
        }

        header {
            border-bottom: 2px solid #3f75a2;
            padding-bottom: 10px;
            margin-bottom: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        h1 {
            color: #3b5998;
            font-size: 24px;
            margin: 0;
        }

        .subtitle {
            font-size: 11px;
            color: #666;
            margin: 3px 0 0 0;
        }

        .filter-box select {
            padding: 4px;
            font-size: 13px;
            border: 1px solid #a9a9a9;
            border-radius: 3px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
            margin-bottom: 15px;
        }

        th {
            background-color: #f1f1f1;
            color: #333;
            font-weight: bold;
            text-align: left;
            border: 1px solid #d9d9d9;
            padding: 6px 8px;
        }

        td {
            border: 1px solid #e1e1e1;
            padding: 6px 8px;
        }

        tr:nth-child(even) {
            background-color: #f9f9f9;
        }

        tr:hover {
            background-color: #f5f5f5;
        }

        .pagination-bar {
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            font-size: 13px;
            padding-top: 10px;
            border-top: 1px dashed #ccc;
        }

        .btn {
            color: #0000ee;
            text-decoration: none;
            padding: 4px 8px;
            border: 1px solid #ccc;
            background: #f8f8f8;
            border-radius: 3px;
        }

        .btn:hover {
            background: #eee;
            text-decoration: underline;
        }

        .btn.disabled {
            color: #888;
            pointer-events: none;
            background: #f0f0f0;
            border-color: #ddd;
        }

        .category-tag {
            font-weight: bold;
            color: #3f75a2;
        }

        .price-text {
            font-family: monospace;
            font-weight: bold;
        }
    </style>
</head>

<body>

    <div class="container">
        <header>
            <div>
                <h1>Product Directory</h1>
                <p class="subtitle">High-performance cursor pagination across 200,000 records</p>
            </div>

            <div class="filter-box">
                <form method="GET" action="/">
                    <label style="font-size: 13px;" for="cat-select">Filter by: </label>
                    <select id="cat-select" name="category" onchange="this.form.submit()">
                        <option value="">All Categories</option>
                        <% categories.forEach(function(cat) { %>
                            <option value="<%= cat %>" <%=currentCategory===cat ? 'selected' : '' %>><%= cat %></option>
                        <% }); %>
                    </select>
                </form>
            </div>
        </header>

        <main>
            <div style="background: #fff; border: 1px solid #d9d9d9; padding: 12px; margin-bottom: 20px; border-radius: 3px;">
                <strong style="color: #3b5998; font-size: 14px; display: block; margin-bottom: 8px;">Create New Entry (Test Real-Time Injection)</strong>
                <form method="POST" action="/add" style="display: flex; gap: 15px; align-items: center; font-size: 13px;">
                    <div>
                        <label for="new-name">Name: </label>
                        <input type="text" id="new-name" name="name" required style="padding: 3px; border: 1px solid #ccc; width: 200px;">
                    </div>

                    <div>
                        <label for="new-cat">Category: </label>
                        <select id="new-cat" name="category" required style="padding: 3px; border: 1px solid #ccc;">
                            <% categories.forEach(function(cat) { %>
                                <option value="<%= cat %>"><%= cat %></option>
                            <% }); %>
                        </select>
                    </div>

                    <div>
                        <label for="new-price">Price ($): </label>
                        <input type="number" id="new-price" name="price" step="0.01" min="0" required style="padding: 3px; border: 1px solid #ccc; width: 80px;">
                    </div>

                    <button type="submit" style="padding: 4px 12px; background: #3f75a2; color: white; border: 1px solid #2a5273; border-radius: 3px; cursor: pointer; font-weight: bold;">
                        Submit Entry
                    </button>
                </form>
            </div>

            <table>
                <thead>
                    <tr>
                        <th style="width: 40%;">Product Name</th>
                        <th style="width: 20%;">Category</th>
                        <th style="width: 15%;">Price</th>
                        <th style="width: 15%;">Date Added</th>
                        <th style="width: 10%; text-align: center;">Actions</th>
                    </tr>
                </thead>
                <tbody id="product-table-body">
                    <% products.forEach(function(product) { %>
                        <tr>
                            <td><%= product.name %></td>
                            <td><span class="category-tag"><%= product.category %></span></td>
                            <td><span class="price-text">$<%= Number(product.price).toFixed(2) %></span></td>
                            <td style="color: #666;"><%= new Date(product.createdAt).toLocaleString() %></td>
                            <td style="text-align: center;">
    <% if (product && product.id) { %>
        <form method="POST" action="/delete/<%= product.id %>?_method=DELETE" style="display:inline;" onsubmit="return confirm('Are you sure you want to drop this record?')">
            <button type="submit" style="background: none; border: none; color: #cc0000; font-size: 11px; font-weight: bold; cursor: pointer; padding: 0; font-family: verdana, arial, sans-serif;">
                [Delete]
            </button>
        </form>
    <% } %>
</td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>

            <div class="pagination-bar">
                <% if (prevCursor || prevHistory) { %>
                    <a href="/?category=<%= currentCategory %>&cursor=<%= prevCursor %>&history=<%= prevHistory %>" class="btn">
                        &larr; Previous Page
                    </a>
                <% } else if (products.length > 0 && typeof nextHistory !== 'undefined' && nextHistory !== '') { %>
                    <a href="/?category=<%= currentCategory %>" class="btn">
                        &larr; Back to Page 1
                    </a>
                <% } else { %>
                    <span class="btn disabled">&larr; Previous Page</span>
                <% } %>

                <a href="/?category=<%= currentCategory %>&cursor=<%= nextCursor %>&history=<%= nextHistory %>"
                   class="btn <%= !nextCursor ? 'disabled' : '' %>">
                    Next Page &rarr;
                </a>
            </div>
        </main>
    </div>

</body>
</html>